# .env.example — Environment variable template for langgraph-agent-stack
#
# Copy this file to .env and fill in real values before starting the application.
#
#   cp .env.example .env
#
# NEVER commit the .env file to source control — it is listed in .gitignore.
# This example file is safe to commit: it contains no real credentials.

# =============================================================================
# LLM PROVIDER SELECTION
# =============================================================================

# Which LLM provider to use.
# Allowed values: anthropic | openai | google | bedrock | azure | ollama
# Default: anthropic
LLM_PROVIDER=anthropic

# =============================================================================
# ANTHROPIC (Claude) — LLM_PROVIDER=anthropic
# Install: uv sync --extra anthropic
# =============================================================================

ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-real-key

# Claude model identifier. Default: claude-3-5-sonnet-20241022
# Other options: claude-3-haiku-20240307, claude-3-opus-20240229
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# OPENAI (GPT) — LLM_PROVIDER=openai
# Install: uv sync --extra openai
# =============================================================================

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# =============================================================================
# GOOGLE (Gemini) — LLM_PROVIDER=google
# Install: uv sync --extra google
# =============================================================================

# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-1.5-pro

# =============================================================================
# AWS BEDROCK — LLM_PROVIDER=bedrock
# Install: uv sync --extra bedrock
# =============================================================================

# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# =============================================================================
# AZURE OPENAI — LLM_PROVIDER=azure
# Install: uv sync --extra openai
# =============================================================================

# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# =============================================================================
# OLLAMA (local) — LLM_PROVIDER=ollama
# Install: uv sync --extra ollama
# No API key required — Ollama runs locally.
# =============================================================================

# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# =============================================================================
# LLM GENERATION
# =============================================================================

# Maximum number of tokens the LLM is allowed to generate per call.
# Default: 4096
MAX_TOKENS=4096

# =============================================================================
# MEMORY BACKEND
# =============================================================================

# Which persistence backend to use for LangGraph checkpointing.
# Allowed values: sqlite | redis
# Default: sqlite (no extra infrastructure required)
MEMORY_BACKEND=sqlite

# Path to the SQLite database file.
# Used when MEMORY_BACKEND=sqlite.
# Default: ./data/agent_memory.db
SQLITE_PATH=./data/agent_memory.db

# Redis connection URL.
# Required only when MEMORY_BACKEND=redis.
# Format: redis://[username:password@]host[:port][/db]
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API SERVER
# =============================================================================

# Host address the uvicorn server binds to.
# Default: 0.0.0.0
API_HOST=0.0.0.0

# TCP port the API server listens on.
# Default: 8000
API_PORT=8000

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Python logging level.
# Allowed values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================

# Allowed values: development | staging | production
# Default: development
ENVIRONMENT=development
