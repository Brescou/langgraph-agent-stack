# .env.example — Environment variable template for langgraph-agent-stack
#
# Copy this file to .env and fill in real values before starting the application.
#
#   cp .env.example .env
#
# NEVER commit the .env file to source control — it is listed in .gitignore.
# This example file is safe to commit: it contains no real credentials.

# =============================================================================
# REQUIRED
# =============================================================================

# Anthropic API key used by langchain-anthropic to call Claude models.
# Obtain yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-real-key

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Claude model identifier passed to langchain-anthropic.
# Default: claude-3-5-sonnet-20241022
# Other options: claude-3-haiku-20240307, claude-3-opus-20240229
MODEL_NAME=claude-3-5-sonnet-20241022

# Maximum number of tokens the LLM is allowed to generate per call.
# Lower values reduce latency and cost; higher values allow longer responses.
# Default: 4096
MAX_TOKENS=4096

# =============================================================================
# MEMORY BACKEND
# =============================================================================

# Which persistence backend to use for LangGraph checkpointing.
# Allowed values: sqlite | redis
# Default: sqlite (no extra infrastructure required)
MEMORY_BACKEND=sqlite

# Path to the SQLite database file.
# Used when MEMORY_BACKEND=sqlite.
# Default: ./data/agent_memory.db
SQLITE_PATH=./data/agent_memory.db

# Redis connection URL.
# Required only when MEMORY_BACKEND=redis.
# Format: redis://[username:password@]host[:port][/db]
# Example for a local Redis: redis://localhost:6379/0
# Example with auth:         redis://default:mysecretpassword@redis-host:6379/0
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API SERVER
# =============================================================================

# Host address the uvicorn server binds to.
# Use 0.0.0.0 to accept connections from all network interfaces (default for containers).
# Use 127.0.0.1 for local-only access during development.
# Default: 0.0.0.0
API_HOST=0.0.0.0

# TCP port the API server listens on.
# Default: 8000
API_PORT=8000

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Python logging level for the application.
# Allowed values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
# Use DEBUG during local development for verbose agent step output.
LOG_LEVEL=INFO

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================

# Identifies the current deployment environment.
# Surfaced in the /health endpoint response and structured log output.
# Allowed values: development | staging | production
# Default: development
ENVIRONMENT=development
